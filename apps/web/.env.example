# Red de Stellar para la wallet. TESTNET por default; PUBLIC para mainnet.
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# Pinata (IPFS pinning provider) — JWT con permisos:
# pinFileToIPFS, pinJSONToIPFS, addPinObject, getPinObject,
# listPinObjects, pinList, userPinnedDataTotal
# Server-side only, NUNCA exponer al cliente. Ver apps/web/docs/pinata-setup.md.
PINATA_JWT=
