# ── Frontend (safe to expose to the browser) ─────────────────────────────────

# Stellar network the wallet connects to. Keep TESTNET until mainnet launch.
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# Supabase project URL — find it in Supabase dashboard → Settings → API.
# This is public; safe to commit to frontend bundles.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anon key — find it in Supabase dashboard → Settings → API.
# This is the public key, intentionally safe to expose. RLS enforces access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Server-side only (API routes, indexer) ────────────────────────────────────
# Never use these in client components — they must stay server-side.

# Supabase service role key — bypasses RLS. Used only by the indexer worker.
# Find it in Supabase dashboard → Settings → API → service_role key.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=

# ── IPFS / file uploads ───────────────────────────────────────────────────────

# Pinata JWT — API v3, needs "Files: Write" scope (pinata.upload.public.file).
# Legacy pinning scopes do not work. Server-side only.
PINATA_JWT=

# Optional: dedicated Pinata gateway for retrieval (e.g. your-sub.mypinata.cloud).
# Falls back to the public gateway.pinata.cloud when unset.
# PINATA_GATEWAY=

# ── Indexer tuning (optional) ─────────────────────────────────────────────────

# Override the start ledger for the indexer's first poll. Useful to limit
# history on fresh deploys. Defaults to 0 (oldest available ledger).
# INDEXER_START_LEDGER=

# Polling interval in milliseconds for the continuous indexer loop.
# Defaults to 6000 (≈ one Stellar ledger). Raise for lower RPC usage.
# POLL_INTERVAL_MS=6000

# ── Cron / deployment ─────────────────────────────────────────────────────────

# Secret used to authenticate the /api/indexer/poll cron endpoint.
# Generate with: openssl rand -hex 32
# CRON_SECRET=
